{
  "name": "actions-insights",
  "version": "1.0.0",
  "description": "TeamCity-style test reports for GitHub Actions",
  "main": "dist/index.js",
  "workspaces": [
    "packages/*",
    "web",
    "docs"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.js && ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "generate-sample": "tsx scripts/generate-sample.ts",
    "generate-local": "tsx scripts/generate-local.ts",
    "import-history": "tsx scripts/import-history.ts",
    "build:web": "npm run build --workspace=@actions-insights/web",
    "docs:build": "npm run build --workspace=actions-insights-docs",
    "docs:start": "npm run start --workspace=actions-insights-docs",
    "publish:extension": "bash scripts/publish-extension.sh"
  },
  "keywords": [
    "github-actions",
    "test-reports",
    "trx",
    "junit",
    "nunit",
    "xunit"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/artifact": "^2.1.1",
    "@actions/cache": "^3.2.4",
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.0",
    "@actions/glob": "^0.4.0",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vercel/ncc": "^0.38.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
