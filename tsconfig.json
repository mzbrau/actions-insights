{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "lib": ["ES2022"],
    "outDir": "lib",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@actions-insights/history-models": ["packages/history-models/src/index.ts"],
      "@actions-insights/history-publisher": ["packages/history-publisher/src/index.ts"]
    }
  },
  "include": ["src/**/*", "packages/history-models/src/**/*"],
  "exclude": ["node_modules", "dist", "lib", "test", "web", "packages/history-publisher"]
}
