#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_script() {
  local name="$1"
  if [[ -f "${SCRIPT_DIR}/scripts/${name}" ]]; then
    echo "${SCRIPT_DIR}/scripts/${name}"
    return
  fi
  echo "${SCRIPT_DIR}/../../scripts/${name}"
}

case "${1:-}" in
  update)
    exec "$(resolve_script update-history-repo.sh)" "$@"
    ;;
  init)
    exec "$(resolve_script init-history-repo.sh)" "$@"
    ;;
  import)
    exec "$(resolve_script import-history-repo.sh)" "$@"
    ;;
esac

exec "$(resolve_script init-history-repo.sh)" "$@"
